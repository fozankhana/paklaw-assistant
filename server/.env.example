# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Local LLM (Ollama) — https://ollama.com
# Install Ollama, then run:  ollama pull llama3.1
# If Ollama is not running, the API automatically falls back to an
# extractive answer that quotes the retrieved law text, so the app still works.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_TIMEOUT_MS=45000

# Semantic retrieval (optional).
# "off" (default) -> fast lexical BM25 retrieval, no downloads.
# "on"  -> also build local sentence embeddings (downloads a small model on first use).
EMBEDDINGS=off

# How many source passages to feed the model per question.
RETRIEVAL_TOP_K=6

# Local GGUF model (alternative to Ollama, no separate server needed).
# Point this at any GGUF file on disk — e.g. Llama-3.2-3B-Instruct-Q4_K_M.gguf
# Leave blank to skip local model loading (falls back to Ollama, then extractive).
LLAMA_MODEL_PATH=
LLAMA_CONTEXT_SIZE=2048
LLAMA_TIMEOUT_MS=120000
